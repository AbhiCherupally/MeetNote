# Copy this to .env and update the valuesPORT=3001

NODE_ENV=development

# Server ConfigurationJWT_SECRET=your-super-secret-jwt-key-change-in-production

NODE_ENV=productionJWT_EXPIRES_IN=7d

PORT=10000

# Database (Render Postgres - get from Render Dashboard)

# Security (CHANGE THIS!)DATABASE_URL=postgresql://username:password@hostname:5432/database

JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Cache (Render Key Value Store - get from Render Dashboard)  

# AI Services (your API keys)REDIS_URL=redis://redis-hostname:6379

OPENROUTER_API_KEY=your-openrouter-api-key

ASSEMBLYAI_API_KEY=your-assemblyai-api-key# AI Services

OPENROUTER_API_KEY=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

# CORS (your frontend URL)OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

CORS_ORIGIN=https://your-app.netlify.appOPENROUTER_MODEL=mistralai/mistral-7b-instruct:free
ASSEMBLY_AI_KEY=598c0c5952444246ba2c1af3eb010d0b

# Storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=meetnote-recordings

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# Webhooks
WEBHOOK_SECRET=your-webhook-secret

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Chrome Extension
EXTENSION_ID=meetnote-chrome-extension-id